<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>[이름] — Video Editor & AI Creative</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700;800&family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
  :root{
    --bg:        #101012;
    --panel:     #17171a;
    --panel-2:   #1e1e22;
    --line:      #2a2a2f;
    --text:      #f1eee7;
    --text-dim:  #9a978f;
    --amber:     #ffa53d;   /* human craft: cut, grade, comp */
    --teal:      #2dd4bf;   /* generative / AI tools */
    --font-mono: 'JetBrains Mono', ui-monospace, monospace;
    --font-sans: 'Manrope', -apple-system, sans-serif;
  }

  *{ box-sizing:border-box; margin:0; padding:0; }
  html{ scroll-behavior:smooth; }
  @media (prefers-reduced-motion: reduce){ html{ scroll-behavior:auto; } }

  body{
    background:var(--bg);
    color:var(--text);
    font-family:var(--font-sans);
    line-height:1.5;
  }

  a{ color:inherit; }
  a:focus-visible, button:focus-visible{
    outline:2px solid var(--amber);
    outline-offset:3px;
  }

  .eyebrow{
    font-family:var(--font-mono);
    font-size:.72rem;
    letter-spacing:.14em;
    text-transform:uppercase;
    color:var(--text-dim);
  }

  /* ---------- timeline nav ---------- */
  .timeline-nav{
    position:sticky; top:0; z-index:50;
    background:rgba(16,16,18,.92);
    backdrop-filter:blur(6px);
    border-bottom:1px solid var(--line);
    overflow-x:auto;
  }
  .timeline-track{
    display:flex; align-items:stretch;
    min-width:600px;
    padding:0 24px;
  }
  .timeline-track button{
    background:none; border:none; cursor:pointer;
    color:var(--text-dim);
    font-family:var(--font-mono);
    font-size:.72rem;
    padding:14px 18px 12px;
    border-bottom:2px solid transparent;
    white-space:nowrap;
    transition:color .15s ease, border-color .15s ease;
  }
  @media (prefers-reduced-motion: reduce){
    .timeline-track button{ transition:none; }
  }
  .timeline-track button .tc{ display:block; opacity:.6; margin-bottom:3px; }
  .timeline-track button.active{
    color:var(--amber);
    border-bottom-color:var(--amber);
  }
  .timeline-track button:hover{ color:var(--text); }

  section{ padding:96px 24px; border-bottom:1px solid var(--line); }
  .wrap{ max-width:960px; margin:0 auto; }

  .track-label{
    display:inline-flex; align-items:center; gap:8px;
    font-family:var(--font-mono);
    font-size:.72rem;
    color:var(--amber);
    border:1px solid var(--amber);
    padding:3px 9px;
    border-radius:2px;
    margin-bottom:20px;
  }
  .track-label.ai{ color:var(--teal); border-color:var(--teal); }
  .track-label::before{ content:"▮"; font-size:.6rem; }

  /* ---------- hero / reel ---------- */
  .hero{ padding-top:64px; }
  .hero h1{
    font-family:var(--font-mono);
    font-weight:800;
    font-size:clamp(2rem, 5.5vw, 3.6rem);
    line-height:1.05;
    letter-spacing:-.01em;
  }
  .hero h1 .role{
    display:block;
    font-family:var(--font-sans);
    font-weight:500;
    font-size:1.1rem;
    color:var(--text-dim);
    margin-top:14px;
  }
  .hero p.intro{
    max-width:56ch;
    margin-top:22px;
    color:var(--text-dim);
    font-size:1.02rem;
  }

  .reel-frame{
    margin-top:44px;
    position:relative;
    border:1px solid var(--line);
    background:var(--panel);
    aspect-ratio:16/9;
    overflow:hidden;
  }
  .reel-frame iframe{ width:100%; height:100%; border:0; display:block; }
  .reel-frame .tc-burn{
    position:absolute; bottom:10px; left:12px;
    font-family:var(--font-mono); font-size:.72rem;
    color:var(--amber); background:rgba(0,0,0,.5);
    padding:2px 8px; pointer-events:none;
  }

  /* ---------- profile ---------- */
  .profile-grid{
    display:grid; grid-template-columns:1.1fr .9fr; gap:56px;
  }
  @media (max-width:720px){ .profile-grid{ grid-template-columns:1fr; } }
  .profile-grid h2{
    font-family:var(--font-mono);
    font-size:1.6rem; font-weight:700; margin-bottom:18px;
  }
  .profile-grid p{ color:var(--text-dim); margin-bottom:14px; }
  .stat-list{ display:flex; flex-direction:column; gap:16px; }
  .stat-list div{
    border-left:2px solid var(--amber);
    padding-left:14px;
  }
  .stat-list .num{ font-family:var(--font-mono); font-size:1.4rem; font-weight:700; }
  .stat-list .label{ color:var(--text-dim); font-size:.85rem; margin-top:2px; }

  /* ---------- toolkit ---------- */
  .toolkit-grid{
    display:grid; grid-template-columns:repeat(2,1fr); gap:1px;
    background:var(--line);
    border:1px solid var(--line);
  }
  @media (max-width:640px){ .toolkit-grid{ grid-template-columns:1fr; } }
  .tool-card{
    background:var(--panel);
    padding:22px 24px;
  }
  .tool-card h3{
    font-family:var(--font-mono);
    font-size:.95rem;
    display:flex; align-items:center; gap:8px;
    margin-bottom:6px;
  }
  .tool-card h3::before{ content:"●"; color:var(--amber); font-size:.55rem; }
  .tool-card.ai h3::before{ color:var(--teal); }
  .tool-card p{ color:var(--text-dim); font-size:.88rem; }

  /* ---------- work ---------- */
  .work-grid{
    display:grid; grid-template-columns:repeat(3,1fr); gap:18px;
    margin-top:36px;
  }
  @media (max-width:820px){ .work-grid{ grid-template-columns:1fr; } }
  .work-card{
    background:var(--panel);
    border:1px solid var(--line);
    overflow:hidden;
  }
  .work-card .thumb{
    aspect-ratio:16/9; background:var(--panel-2);
    display:flex; align-items:center; justify-content:center;
    color:var(--text-dim); font-family:var(--font-mono); font-size:.75rem;
    position:relative;
  }
  .work-card iframe{ width:100%; height:100%; border:0; display:block; }
  .work-card .meta{ padding:16px 18px; }
  .work-card .meta h3{ font-size:1rem; font-weight:700; margin-bottom:6px; }
  .work-card .meta .tags{
    display:flex; gap:6px; flex-wrap:wrap; margin-top:10px;
  }
  .work-card .meta .tags span{
    font-family:var(--font-mono); font-size:.68rem;
    color:var(--text-dim); border:1px solid var(--line);
    padding:2px 7px;
  }

  /* ---------- contact / out point ---------- */
  .contact{ border-bottom:none; }
  .contact h2{
    font-family:var(--font-mono);
    font-size:clamp(1.8rem, 4vw, 2.6rem);
    font-weight:800;
  }
  .contact p{ color:var(--text-dim); margin-top:14px; max-width:52ch; }
  .contact-links{
    display:flex; flex-wrap:wrap; gap:14px;
    margin-top:32px;
  }
  .contact-links a{
    font-family:var(--font-mono); font-size:.85rem;
    border:1px solid var(--line);
    padding:11px 18px;
    text-decoration:none;
    transition:border-color .15s ease, color .15s ease;
  }
  @media (prefers-reduced-motion: reduce){ .contact-links a{ transition:none; } }
  .contact-links a:hover{ border-color:var(--amber); color:var(--amber); }

  footer{
    padding:28px 24px;
    font-family:var(--font-mono);
    font-size:.7rem;
    color:var(--text-dim);
    text-align:center;
  }
</style>
</head>
<body>

<nav class="timeline-nav" aria-label="섹션 이동">
  <div class="timeline-track">
    <button data-target="reel" class="active"><span class="tc">00:00:00</span>REEL</button>
    <button data-target="profile"><span class="tc">00:00:15</span>PROFILE</button>
    <button data-target="toolkit"><span class="tc">00:00:30</span>TOOLKIT</button>
    <button data-target="work"><span class="tc">00:00:45</span>WORK</button>
    <button data-target="contact"><span class="tc">00:01:00</span>CONTACT</button>
  </div>
</nav>

<section id="reel" class="hero">
  <div class="wrap">
    <p class="eyebrow">SHOWREEL — 2026</p>
    <h1>[이름]
      <span class="role">Video Editor & AI Creative — [한 줄 소개, 예: 편집부터 생성형 AI 비주얼까지]</span>
    </h1>
    <p class="intro">
      [자기소개 2~3문장. 어떤 종류의 영상을 주로 다루는지, 어떤 강점을 갖고 있는지 짧게 적어주세요.]
    </p>
    <div class="reel-frame">
      <!-- Vimeo 또는 YouTube 임베드로 교체하세요 -->
      <iframe src="https://player.vimeo.com/video/YOUR_VIDEO_ID" title="Showreel" allow="autoplay; fullscreen; picture-in-picture" allowfullscreen></iframe>
      <span class="tc-burn">00:00:00:00</span>
    </div>
  </div>
</section>

<section id="profile">
  <div class="wrap profile-grid">
    <div>
      <span class="track-label">V1 — PROFILE</span>
      <h2>어떤 작업을 하나요</h2>
      <p>[경력, 전문 분야, 작업 스타일에 대한 설명을 적어주세요. 예: N년간 유튜브/광고/브랜드 영상 편집을 해왔고, 최근에는 생성형 AI 툴을 접목한 제작에 집중하고 있습니다.]</p>
      <p>[두 번째 문단 — 협업 스타일, 선호하는 프로젝트 종류 등]</p>
    </div>
    <div class="stat-list">
      <div><div class="num">[N]년</div><div class="label">영상 편집 경력</div></div>
      <div><div class="num">[N]개+</div><div class="label">완료 프로젝트</div></div>
      <div><div class="num">[N]개</div><div class="label">주요 클라이언트 / 채널</div></div>
    </div>
  </div>
</section>

<section id="toolkit">
  <div class="wrap">
    <span class="track-label">V2 — TOOLKIT</span>
    <h2 style="font-family:var(--font-mono); font-size:1.6rem; margin-bottom:24px;">사용 툴</h2>
    <div class="toolkit-grid">
      <div class="tool-card">
        <h3>Premiere Pro / DaVinci Resolve</h3>
        <p>편집 · 컬러그레이딩 · 후반작업</p>
      </div>
      <div class="tool-card">
        <h3>After Effects</h3>
        <p>모션그래픽 · 합성</p>
      </div>
      <div class="tool-card">
        <h3>Photoshop / Illustrator</h3>
        <p>썸네일 · 그래픽 · 디자인</p>
      </div>
      <div class="tool-card ai">
        <h3>Midjourney</h3>
        <p>AI 이미지 생성</p>
      </div>
      <div class="tool-card ai">
        <h3>Kling</h3>
        <p>AI 영상 생성</p>
      </div>
      <div class="tool-card ai">
        <h3>Suno AI</h3>
        <p>AI 음악 · 사운드</p>
      </div>
      <div class="tool-card ai">
        <h3>ComfyUI <span style="color:var(--text-dim); font-weight:400;">(학습 중)</span></h3>
        <p>커스텀 AI 워크플로우 구축</p>
      </div>
    </div>
  </div>
</section>

<section id="work">
  <div class="wrap">
    <span class="track-label">V3 — WORK</span>
    <h2 style="font-family:var(--font-mono); font-size:1.6rem;">대표 작업</h2>
    <div class="work-grid">
      <div class="work-card">
        <div class="thumb">
          <iframe src="https://player.vimeo.com/video/YOUR_VIDEO_ID_1" title="Project 1" allowfullscreen></iframe>
        </div>
        <div class="meta">
          <h3>[프로젝트 제목 1]</h3>
          <p style="color:var(--text-dim); font-size:.85rem;">[한 줄 설명 — 클라이언트, 목적, 사용 툴 등]</p>
          <div class="tags"><span>Premiere</span><span>DaVinci</span></div>
        </div>
      </div>
      <div class="work-card">
        <div class="thumb">
          <iframe src="https://player.vimeo.com/video/YOUR_VIDEO_ID_2" title="Project 2" allowfullscreen></iframe>
        </div>
        <div class="meta">
          <h3>[프로젝트 제목 2]</h3>
          <p style="color:var(--text-dim); font-size:.85rem;">[한 줄 설명]</p>
          <div class="tags"><span>Midjourney</span><span>Kling</span></div>
        </div>
      </div>
      <div class="work-card">
        <div class="thumb">
          <iframe src="https://player.vimeo.com/video/YOUR_VIDEO_ID_3" title="Project 3" allowfullscreen></iframe>
        </div>
        <div class="meta">
          <h3>[프로젝트 제목 3]</h3>
          <p style="color:var(--text-dim); font-size:.85rem;">[한 줄 설명]</p>
          <div class="tags"><span>After Effects</span><span>Suno AI</span></div>
        </div>
      </div>
    </div>
  </div>
</section>

<section id="contact" class="contact">
  <div class="wrap">
    <span class="track-label">OUT POINT</span>
    <h2>같이 작업해요</h2>
    <p>[문의 방식에 대한 짧은 안내 — 예: 이메일로 연락 주시면 24시간 내 회신드립니다.]</p>
    <div class="contact-links">
      <a href="mailto:your@email.com">EMAIL — your@email.com</a>
      <a href="https://vimeo.com/yourprofile" target="_blank" rel="noopener">VIMEO</a>
      <a href="https://instagram.com/yourprofile" target="_blank" rel="noopener">INSTAGRAM</a>
      <a href="https://linkedin.com/in/yourprofile" target="_blank" rel="noopener">LINKEDIN</a>
    </div>
  </div>
</section>

<footer>© 2026 [이름]. Built as a single-page site for GitHub Pages.</footer>

<script>
  (function(){
    var buttons = document.querySelectorAll('.timeline-track button');
    var sections = Array.prototype.map.call(buttons, function(b){
      return document.getElementById(b.dataset.target);
    });

    buttons.forEach(function(btn){
      btn.addEventListener('click', function(){
        document.getElementById(btn.dataset.target).scrollIntoView({behavior:'smooth'});
      });
    });

    var observer = new IntersectionObserver(function(entries){
      entries.forEach(function(entry){
        if(entry.isIntersecting){
          var id = entry.target.id;
          buttons.forEach(function(b){
            b.classList.toggle('active', b.dataset.target === id);
          });
        }
      });
    }, { rootMargin: '-45% 0px -50% 0px', threshold: 0 });

    sections.forEach(function(s){ if(s) observer.observe(s); });
  })();
</script>

</body>
</html>
